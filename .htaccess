RewriteEngine On

# XAMPP/local development: if a request reaches Apache over HTTPS on localhost,
# send it back to HTTP. Chrome's certificate interstitial can still appear before
# Apache/PHP runs; in that case open the same URL with http:// directly.
RewriteCond %{HTTPS} on
RewriteCond %{HTTP_HOST} ^(localhost|127\.0\.0\.1)(:[0-9]+)?$ [NC]
RewriteRule ^ http://%{HTTP_HOST}%{REQUEST_URI} [R=302,L]
