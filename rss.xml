<?php require_once __DIR__.'/app/bootstrap.php'; if(!installed()){http_response_code(503);exit;} header('Content-Type: application/rss+xml; charset=utf-8'); $site=setting('site_name','livedoorアンテナ'); echo '<?xml version="1.0" encoding="UTF-8"?>'; ?><rss version="2.0" xmlns:media="http://search.yahoo.com/mrss/"><channel><title><?=e($site)?></title><link><?=e(current_origin().app_url('/'))?></link><description><?=e(setting('site_description',''))?></description><?php foreach(db()->query("SELECT * FROM post_history WHERE result='OK' ORDER BY posted_at DESC LIMIT 20") as $p): ?><item><title><?=e($p['main_title'])?></title><link><?=e($p['livedoor_url'])?></link><pubDate><?=date(DATE_RSS,strtotime($p['posted_at']))?></pubDate><description><?=e($p['article_count'].'件の記事をまとめました。')?></description><?php if($p['image_url']): ?><media:thumbnail url="<?=e($p['image_url'])?>"/><enclosure url="<?=e($p['image_url'])?>" type="image/jpeg" /><?php endif; ?></item><?php endforeach; ?></channel></rss>
